								"newText": "\\documentclass[\n  12pt,\n  a4paper,\n  twoside,\n  openright\n]{memoir}\n\n\\input{preamble}\n\n\\begin{document}\n\n\\frontmatter\n\n\\input{titlepage}\n\n\\tableofcontents\n\n\\etocsettocstyle{}{}\n\n\\input{preface}\n\n\\mainmatter\n\n\\chapter{Essentials of Geometry}\n\n\\localtableofcontents*\n\n{\\large\\bfseries Perimeter}\n\nThe distance around a rectangle is called its \\textbf{perimeter.}\n\n{\\large\\bfseries Circumference}\n\nThe distance around a circle is called its \\textbf{circumference.}\n\n% \\settasks{\n%   label-width=0em,\n%   label=\\makebox[0pt][r]{\\textbf{\\arabic*.}},\n%   item-indent=2em,\n% }\n\n% \\begin{tasks}(4) % 3 columns\n%   \\task one\n%   \\task one\n%   \\task one\n%   \\task one\n%   \\task one\n%   \\task one\n%   \\task one\n%   \\task one\n% \\end{tasks}\n\n\\section{Points, Lines, and Planes}\n\n\\subsection{Undefined Terms}\n\n\\textbf{Undefined terms}: In geometry, the words \\textit{point}, \\textit{line},\nand \\textit{plane} are undefined terms.\nThese words do not have formal definitions, but there is agreement about\nwhat they mean.\n\n\\textbf{Point}: A point has no dimension. It is represented by a dot.\n\n\\begin{figure}[H]\n\t\\centering\n\t\\includegraphics[width=0.08\\textwidth]{figures/chapter-1/point.pdf}\n\t\\caption*{point $A$}\n\\end{figure}\n\n\\textbf{Line}: A line has one dimension. It is\nrepresented by a line with two arrowheads,\nbut it extends without end.\n\nThrough any two points, there is exactly one\nline. You can use any two points on a line\nto name it.\n\n\\begin{figure}[H]\n\t\\centering\n\t\\includegraphics[width=0.5\\textwidth]{figures/chapter-1/line.pdf}\n\t\\caption*{line \\(\\ell\\), line \\(AB\\) (\\(\\overleftrightarrow{AB}\\)),\n\t\tor line \\(BA\\) (\\(\\overleftrightarrow{BA}\\))}\n\\end{figure}\n\n\\textbf{Plane}: A plane has two dimensions. It is\nrepresented by a shape that looks like a floor\nor a wall, but it extends without end.\n\nThrough any three points not on the same\nline, there is exactly one plane. You can use\nthree points that are not all on the same line\nto name a plane.\n\n\\begin{figure}[H]\n\t\\centering\n\t\\includegraphics[width=0.4\\textwidth]{figures/chapter-1/plane.pdf}\n\t\\caption*{plane \\(\\symbf{M}\\) or plane \\(ABC\\)}\n\\end{figure}\n\n\\textbf{Collinear points}: Collinear points are points that lie on the same line.\n\n\\textbf{Coplanar points}: Coplanar points are points that lie in the same plane.\n\n\\begin{example}\\label{exa:point}\n\n\tName points, lines, and planes\n\n\t\\begin{figure}[H]\n\t\t\\centering\n\t\t\\includegraphics[width=0.6\\textwidth]{figures/chapter-1/example-1.pdf}\n\t\\end{figure}\n\n\t\\begin{enumerate}[]\n\t\t\\item Give two other names for \\(\\overleftrightarrow{PQ}\\)\n\n\t\t\\item Give two other names for plane \\(\\symbf{R}\\).\n\n\t\t\\item Name three points that are collinear.\n\n\t\t\\item Name four points that are coplanar.\n\n\t\t\\item Give two other names for \\(\\overleftrightarrow{ST}\\) .\n\n\t\t\\item Name a point that is not coplanar with points \\(Q\\), \\(S\\), and \\(T\\).\n\t\\end{enumerate}\n\n\t\\begin{solution}\n\t\t\\begin{enumerate}[]\n\t\t\t\\item Line \\(n\\), \\(\\overleftrightarrow{QP}\\).\n\n\t\t\t\\item Plane \\(VST\\), plane \\(VPT\\).\n\n\t\t\t\\item Points \\(S\\), \\(P\\), and \\(T\\).\n\n\t\t\t\\item Points \\(V\\), \\(S\\), \\(P\\), and \\(T\\).\n\n\t\t\t\\item Line \\(m\\), \\(\\overleftrightarrow{PT}\\).\n\n\t\t\t\\item Point \\(V\\).\n\t\t\\end{enumerate}\n\t\\end{solution}\n\\end{example}\n\n\\subsection{Defined Terms}\n\n\\textbf{Defined terms}: In geometry, terms that can be described using known\nwords such as \\textit{point} or \\textit{line} are called defined terms.\n\n\\textbf{Segment}: The line segment \\(AB\\), or segment \\(AB\\),\n(written as \\(\\overline{AB}\\)) consists of the endpoints \\(A\\) and\n\\(B\\) and all points on \\(\\overleftrightarrow{AB}\\)\nthat are between \\(A\\) and \\(B\\).\n\nNote that \\(\\overline{AB}\\) can also be named \\(\\overline{BA}\\).\n\n\\begin{figure}[H]\n\t\\centering\n\t\\includegraphics[width=0.4\\textwidth]{figures/chapter-1/segment.pdf}\n\t\\caption*{segment \\(\\overline{AB}\\) or \\(\\overline{BA}\\)}\n\\end{figure}\n\n\\textbf{Ray}: The ray \\(AB\\) (written as \\(\\overrightarrow{AB}\\)) consists of\nthe point \\(A\\) and all points on \\(\\overleftrightarrow{AB}\\) that lie on the\nsame side of \\(A\\) as \\(B\\).\n\nNote that \\(\\overrightarrow{AB}\\) and \\(\\overrightarrow{BA}\\) are different rays.\n\n\\begin{figure}[H]\n\t\\centering\n\t\\includegraphics[width=0.4\\textwidth]{figures/chapter-1/ray.pdf}\n\t\\caption*{rays $\\overrightarrow{AB}$ and $\\overrightarrow{BA}$}\n\\end{figure}\n\n\\textbf{Opposite rays}: If point \\(C\\) lies on \\(\\overleftrightarrow{AB}\\) between\n\\(A\\) and \\(B\\), then \\(\\overrightarrow{CA}\\) and \\(\\overrightarrow{CB}\\)\nare opposite rays.\n\n\\begin{figure}[H]\n\t\\centering\n\t\\includegraphics[width=0.5\\textwidth]{figures/chapter-1/opposite-rays.pdf}\n\t\\caption*{opposite rays \\(\\overrightarrow{CA}\\) and \\(\\overrightarrow{CB}\\)}\n\\end{figure}\n\nSegments and rays are collinear if they lie on the same line. So, opposite rays\nare collinear. Lines, segments, and rays are coplanar if they lie in the\nsame plane.\n\n\\begin{example}\n\tName segments, rays, and opposite rays\n\n\t\\begin{figure}[H]\n\t\t\\centering\n\t\t\\includegraphics[width=0.4\\textwidth]{figures/chapter-1/example-2.pdf}\n\t\\end{figure}\n\n\t\\begin{enumerate}\n\t\t\\item Give another name for \\(\\overline{GH}\\).\n\n\t\t\\item Name all rays with endpoint \\(J\\). Which of these rays are opposite rays?\n\n\t\t\\item Give another name for \\(\\overline{EF}\\).\n\n\t\t\\item Are \\(\\overrightarrow{HJ}\\) and \\(\\overrightarrow{JH}\\)\n\t\t      the same ray? Are \\(\\overrightarrow{HJ}\\)\n\t\t      and \\(\\overrightarrow{HG}\\) the same ray?\n\t\\end{enumerate}\n\n\t\\begin{solution}\n\t\t\\begin{enumerate}\n\t\t\t\\item Another name for \\(\\overrightarrow{GH}\\) is \\(\\overrightarrow{HG}\\).\n\n\t\t\t\\item The rays with endpoint \\(J\\) are \\(\\overrightarrow{JE}\\),\n\t\t\t      \\(\\overrightarrow{JG}\\), \\(\\overrightarrow{JF}\\), and\n\t\t\t      \\(\\overrightarrow{JH}\\).\n\n\t\t\t      The pairs of opposite rays with endpoint \\(J\\) are \\(\\overrightarrow{JE}\\)\n\t\t\t      and \\(\\overrightarrow{JF}\\), and \\(\\overrightarrow{JG}\\) and \\(\\overrightarrow{JH}\\).\n\n\t\t\t\\item Another name for \\(\\overline{EF}\\) is \\(\\overline{FE}\\).\n\n\t\t\t\\item \\(\\overrightarrow{HJ}\\) and \\(\\overrightarrow{JH}\\) are not the same rays.\n\t\t\t      \\(\\overrightarrow{HJ}\\) includes the endpoint \\(H\\) and the points on\n\t\t\t      \\(\\overleftrightarrow{HJ}\\) that lie on the same side as point \\(J\\) while\n\t\t\t      \\(\\overrightarrow{JH}\\) includes the endpoint \\(J\\) and the points that lie on\n\t\t\t      the same side as point \\(H\\).\n\n\t\t\t      \\(\\overrightarrow{HJ}\\) and \\(\\overrightarrow{HG}\\) are the same rays\n\t\t\t      since they both contain the endpoint \\(H\\) and all the points of the line\n\t\t\t      \\(\\overrightarrow{HJ}\\) that lie on the same side as point \\(J\\).\n\n\t\t\\end{enumerate}\n\t\\end{solution}\n\\end{example}\n\n\\subsection{Intersections}\n\n\\textbf{Intersection}: Two or more geometric figures intersect if they have one or\nmore points in common. The intersection of the figures is the set of points\nthe figures have in common. Some examples of intersections are\nshown below.\n\n\\begin{figure}[H]\n\t\\centering\n\t\\includegraphics[width=0.4\\textwidth]{figures/chapter-1/intersection-lines.pdf}\n\t\\caption*{The intersection of two different lines is a point.}\n\\end{figure}\n\n\\begin{figure}[H]\n\t\\centering\n\t\\includegraphics[width=0.4\\textwidth]{figures/chapter-1/intersection-planes.pdf}\n\t\\caption*{The intersection of two different planes is a line.}\n\\end{figure}\n\n\\begin{example}\n\tSketch intersections of lines and planes\n\n\t\\begin{enumerate}\n\t\t\\item Sketch a plane and a line that is in the plane.\n\n\t\t\\item Sketch a plane and a line that does not intersect the plane.\n\n\t\t\\item Sketch a plane and a line that intersects the plane at a point.\n\t\\end{enumerate}\n\t\\begin{solution}\n\t\t\\begin{enumerate}\n\t\t\t\\item The line \\(\\ell\\) is in the plane \\(\\symbf{M}\\).\n\n\t\t\t      \\includegraphics[width=0.4\\textwidth]{figures/chapter-1/example3-a.pdf}\n\n\t\t\t\\item The line \\(\\ell\\) does not intersect the plane \\(\\symbf{M}\\).\n\n\t\t\t      \\includegraphics[width=0.4\\textwidth]{figures/chapter-1/example3-b.pdf}\n\n\t\t\t\\item The line \\(\\ell\\) intersects the plane \\(\\symbf{M}\\) at a point.\n\n\t\t\t      \\includegraphics[width=0.4\\textwidth]{figures/chapter-1/example3-c.pdf}\n\t\t\\end{enumerate}\n\t\\end{solution}\n\\end{example}\n\n\\begin{example}\n\tSketch two different lines that intersect a\n\tplane at the same point.\n\n\n\\end{example}\n%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%\n% Back Matter\n%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%\n\n\\backmatter\n\n\\chapter{Appendix}\n\n\\lipsum[21-22]\n\n\\end{document}\n",
