								"newText": "\\documentclass{article}\n\n\\usepackage{amsmath}\n\\usepackage{amssymb}\n\\usepackage{amsthm}\n\n\\usepackage{tcolorbox}\n\\tcbuselibrary{theorems,skins}\n\n% Define the Example environment\n\\newtcbtheorem[\n  number within=section\n]{example}{Example}{\n  enhanced,\n  frame hidden,\n  borderline west={0.5pt}{0pt}{black},\n  coltitle=black,\n    colback=white,\n  colbacktitle=white,\n  fonttitle=\\bfseries,\n  before skip=\\baselineskip,\n  after skip=\\baselineskip\n}{ex}\n\n% Solution environment\n\\newenvironment{solution}\n  {\\par\\noindent\\textbf{Solution}\\par}\n  {\\par\\hfill$\\square$\\par}\n\n\\begin{document}\n\n\\section{Geometry}\n\n\\begin{example}{Pythagorean theorem}{pythagorean}\n\tFind the length of the hypotenuse of a right triangle with sides\n\t$3$ and $4$.\n\n\t\\begin{solution}\n\t\tUsing the Pythagorean theorem,\n\n\t\t\\[\n\t\t\tc^2 = 3^2 + 4^2 = 25\n\t\t\\]\n\n\t\ttherefore,\n\n\t\t\\[\n\t\t\tc=5.\n\t\t\\]\n\t\\end{solution}\n\n\\end{example}\n\n\n\\begin{example}{Area of a circle}{circle-area}\n\tFind the area of a circle with radius $r$.\n\n\t\\begin{solution}\n\t\tThe formula for the area of a circle is\n\n\t\t\\[\n\t\t\tA=\\pi r^2.\n\t\t\\]\n\n\t\tFor $r=3$,\n\n\t\t\\[\n\t\t\tA=9\\pi.\n\t\t\\]\n\t\\end{solution}\n\n\\end{example}\n\n\n\\section{Algebra}\n\n\\begin{example}{Solving a linear equation}{linear-equation}\n\tSolve\n\n\t\\[\n\t\t2x+5=13.\n\t\\]\n\n\t\\begin{solution}\n\t\tSubtract $5$ from both sides:\n\n\t\t\\[\n\t\t\t2x=8.\n\t\t\\]\n\n\t\tDivide by $2$:\n\n\t\t\\[\n\t\t\tx=4.\n\t\t\\]\n\t\\end{solution}\n\n\\end{example}\n\n\nAs shown in Example~\\ref{ex:pythagorean}, the Pythagorean theorem\ncan be used to find unknown sides of right triangles.\n\n\\end{document}",
